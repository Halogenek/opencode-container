# OpenCode CLI Configuration
# This file contains settings for installing and verifying OpenCode CLI

# Version to install (use specific version, not 'latest')
OPENCODE_VERSION="1.2.4"

# SHA256 hash for npm package verification
# To get the hash: npm pack opencode-ai@${OPENCODE_VERSION} && sha256sum opencode-ai-${OPENCODE_VERSION}.tgz
OPENCODE_SHA256="21d0613af451b72fb11bdedc80661606d24c3500a3df0695c1e2ed5dca8178aa"

# Installation command
OPENCODE_INSTALL_CMD="npm install -g opencode-ai@${OPENCODE_VERSION}"

# Package registry (default npm registry)
NPM_REGISTRY="https://registry.npmjs.org/"